# .env.example — copy to .env and fill in real values. NEVER commit .env to git.

# LLM
OPENAI_API_KEY=sk-...

# Database (L3 memory) — use postgresql+psycopg2://user:pass@host/db in production
DATABASE_URL=sqlite:///./investment_advisor.db

# ChromaDB (L4 memory)
CHROMA_PATH=./chroma_db

# Email (SendGrid — replaces raw SMTP)
SENDGRID_API_KEY=SG....
EMAIL_FROM=advisor@yourdomain.com

# File limits
MAX_PDF_MB=10

# RAG defaults (overridable via UI sliders)
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
